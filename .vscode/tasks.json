{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compile and Run",
            "command": "C:/msys64/ucrt64/bin/g++.exe -fdiagnostics-color=always -g -std=c++17 -static main.cpp hashtable.cpp file.cpp -o program.exe ; if ($?) { .\\program.exe }",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Biên dịch và chạy chương trình DSA trực tiếp trong terminal"
        },
        {
            "type": "shell",
            "label": "build all cpp files",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-static",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/hashtable.cpp",
                "${workspaceFolder}/file.cpp",
                "-o",
                "${workspaceFolder}/program.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "compiler: g++"
        }
    ]
}